{
	"name": "mocha-ctrf-json-reporter",
	"version": "0.0.11",
	"description": "A Mocha test reporter to create test results reports",
	"main": "dist/index.js",
	"exports": {
		".": "./dist/index.js",
		"./runtime": "./dist/runtime.js"
	},
	"scripts": {
		"build": "tsc",
		"test": "npm run build && mocha --reporter ./dist/index.js ./tests",
		"lint": "biome lint --write . --unsafe",
		"lint:check": "biome lint .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"all": "npm run lint:check && npm run format:check && npm run test && npm run build",
		"check": "biome check ."
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ctrf-io/mocha-ctrf-json-reporter.git"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"homepage": "https://ctrf.io",
	"files": [
		"dist/",
		"README.md"
	],
	"author": "Matthew Poulton-White",
	"license": "MIT",
	"keywords": [
		"ctrf",
		"common-test-report-format",
		"test-reporting",
		"test-results",
		"testing",
		"json",
		"ci",
		"mocha",
		"mocha-reporter"
	],
	"security": {
		"email": "security@ctrf.io",
		"url": "https://github.com/ctrf-io/.github/blob/main/SECURITY.md"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@types/md5": "2.3.6",
		"@types/mocha": "10.0.10",
		"@types/node": "25.9.2",
		"mocha": "11.7.6",
		"typescript": "6.0.3"
	},
	"dependencies": {
		"ctrf": "0.2.1",
		"md5": "2.3.0"
	},
	"overrides": {
		"serialize-javascript": "7.0.5"
	}
}
